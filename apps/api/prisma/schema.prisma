// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // no output path needed; generates to node_modules/@prisma/client
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model Parent {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  email    String   @unique
  name     String
  password     String
  family    Family?  @relation(fields: [familyId], references: [id])
  familyId     String?      @db.ObjectId
}

model Family {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  parents       Parent[]       
  children   Child[]
  challenges Challenge[]
}

model Child {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  age      Int
  height   Float
  weight   Float
  family   Family     @relation(fields: [familyId], references: [id])
  familyId String     @db.ObjectId
  habits   HabitLog[]
  growthLogs   GrowthLog[]
}

model HabitLog {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  child    Child    @relation(fields: [childId], references: [id])
  childId  String   @db.ObjectId
  date     DateTime @default(now())
  water    Int      @default(0)
  fruits   Int      @default(0)
  veggies  Int      @default(0)
  activity Int      @default(0) // minutes
  screen   Int      @default(0) // minutes
}

model Challenge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
 target      Int
  progress    ChallengeProgress?
  family      Family   @relation(fields: [familyId], references: [id])
  familyId    String   @db.ObjectId
}
model ChallengeProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  challengeId String   @unique
  familyId    String

  progress    Int      @default(0)
  streak      Int      @default(0)
  lastUpdated DateTime?
  completed   Boolean  @default(false)
}
model Tip {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  title   String
  content String
}
model GrowthLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  child     Child    @relation(fields: [childId], references: [id])
  childId   String
  weight    Float
  height    Float
  date      DateTime @default(now())
}